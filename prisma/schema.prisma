generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id        String   @id @default(cuid())
  company   String
  position  String
  status    Status   @default(APPLIED)
  date      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Status {
  APPLIED
  OFFER
  INTERVIEW
  REJECTED
}
